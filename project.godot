[gd_resource type="ProjectSettings" format=3]

config_version = 5

[application]

config/name="Gotot"
config/description="A deeply detailed psychological life-simulation game featuring procedural companion generation and advanced emotional AI."
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.3", "forward_plus")
config/icon="res://assets/icon.svg"

[autoload]

CompanionData="*res://autoload/CompanionData.gd"
LifeSimulator="*res://autoload/LifeSimulator.gd"
InteractionEngine="*res://autoload/InteractionEngine.gd"
EmotionAI="*res://autoload/EmotionAI.gd"
VisualManager="*res://autoload/VisualManager.gd"
SaveSystem="*res://autoload/SaveSystem.gd"

[rendering]

textures/vram_compression/import_etc2_astc=true
Renderer/use_occlusion_culling=true
